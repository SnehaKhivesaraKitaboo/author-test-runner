# Kitaboo Authoring Test Runner — environment configuration
# Copy to .env and fill in your values. Never commit .env to git.

PORT=4321

# Skip MySQL entirely (disk-only runs). If unset, server auto-falls back when MySQL is down.
# SKIP_DB=1

# XAMPP MySQL (database: authoring_test_runner, port 3306)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=authoring_test_runner

# Option A — point Cypress/dashboard at a LOCAL authoring build served by this server.
# By default this standalone app does NOT bundle the KITABOO_Authoring tree.
# To use it, set LOCAL_AUTHORING_DIR to an absolute path of an authoring build and
# LOCAL_AUTHORING=1; it will be mounted at /KITABOO_Authoring/index.html.
# LOCAL_AUTHORING=1
# LOCAL_AUTHORING_DIR=D:\path\to\KITABOO_Authoring
# LOCAL_AUTHORING_PATH=/KITABOO_Authoring/index.html   (override if needed)

# Option B — provide the full remote staging URL
# AUTHORING_LAUNCH_URL=https://stagingauthor.kitaboo.com/html_authoring2_carnegie/index.html?courseId=YOUR_COURSE_ID&userToken=YOUR_TOKEN

# Option C — build URL from parts (staging)
AUTHORING_BASE_URL=https://stagingauthor.kitaboo.com
AUTHORING_PATH=/html_authoring2_carnegie/index.html
AUTHORING_COURSE_ID=
AUTHORING_USER_TOKEN=
