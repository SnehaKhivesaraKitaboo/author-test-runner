# EPUB Automation Tester — STAGING environment template
# Copy to .env on the staging host and fill in real values. Never commit the real .env.

# ── Server ───────────────────────────────────────────────
PORT=4321
# Do not auto-open a browser on a headless server
OPEN_BROWSER=0

# Allow the dashboard to be reached from your staging domain(s).
# Comma-separated list of exact origins (in addition to localhost).
CORS_ORIGINS=https://epub-tester.staging.kitaboo.com

# ── Persistence (MySQL) ──────────────────────────────────
# Set SKIP_DB=1 for disk-only mode (no run history persistence across restarts).
# For full history, point these at the staging MySQL/MariaDB instance and run `npm run db:setup`.
SKIP_DB=0
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=epub_tester
DB_PASSWORD=__SET_IN_STAGING_SECRET_STORE__
DB_NAME=authoring_test_runner

# ── Target authoring app (the system under test) ─────────
# Build the Cypress launch URL from parts, or paste a full AUTHORING_LAUNCH_URL.
AUTHORING_BASE_URL=https://stagingauthor.kitaboo.com
AUTHORING_PATH=/html_authoring2_carnegie/index.html
AUTHORING_COURSE_ID=
AUTHORING_USER_TOKEN=
# AUTHORING_LAUNCH_URL=https://stagingauthor.kitaboo.com/html_authoring2_carnegie/index.html?courseId=...&userToken=...

# ── Optional: QC PDF reference dir (only used by scripts/verify-qc-pdfs.js) ──
# QC_TEST_CASES_DIR=/opt/epub-tester/qc
